{
  "name": "neo-geo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:INNGEST_DEV='1'; pnpm dev\"",
    "inngest:dev": "pnpm dlx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "build": "next build",
    "start": "next start",
    "lint": "biome check --config-path biome.json src supabase package.json tsconfig.json biome.json next.config.ts postcss.config.mjs middleware.ts",
    "lint:fix": "biome check --write --config-path biome.json src supabase package.json tsconfig.json biome.json next.config.ts postcss.config.mjs middleware.ts",
    "format": "biome format --write --config-path biome.json src supabase package.json tsconfig.json biome.json next.config.ts postcss.config.mjs middleware.ts",
    "workflow:new": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/new-dev-branch.ps1",
    "prod:sync": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sync-production-mirror.ps1",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "backfill": "tsx scripts/backfill-daily-metrics.ts",
    "backfill-costs": "tsx scripts/backfill-costs.ts",
    "run-prompts": "tsx scripts/run-all-prompts.ts",
    "kb:index": "tsx scripts/index-knowledge.ts",
    "kb:stats": "tsx scripts/index-knowledge.ts --stats",
    "pause:foodbox": "tsx scripts/pause-foodbox-forbidden-prompts.ts",
    "backfill:mentions": "tsx scripts/backfill-mention-types.ts",
    "backfill:sentiment": "tsx scripts/backfill-sentiment-llm.ts",
    "backfill:position": "tsx scripts/backfill-position-llm.ts",
    "mcp:key": "tsx scripts/generate-mcp-key.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.94.0",
    "@base-ui/react": "^1.4.1",
    "@google/generative-ai": "^0.24.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "googleapis": "^173.0.0",
    "gray-matter": "^4.0.3",
    "inngest": "^4.3.0",
    "lucide-react": "^1.14.0",
    "mdast-util-to-string": "^4.0.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "openai": "^6.37.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "remark-parse": "^11.0.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "unified": "^11.0.5",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@tailwindcss/postcss": "^4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "@tailwindcss/oxide",
      "protobufjs",
      "esbuild",
      "msw"
    ]
  }
}
